# Copy to .env and fill in. .env is git-ignored — never commit real secrets.
#
# Postgres is the persistent store (replaces Baserow at scale). The legacy
# Baserow vars are still read if DATABASE_URL is unset; Postgres takes
# precedence when both are present.

# --- Postgres (primary store) ------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=rbhome

# Host port the dashboard is published on. Caddy reverse-proxies to
# host.docker.internal:<this port>, so it must match your Caddy site config.
DASHBOARD_PORT=8505

# --- Dashboard login ---------------------------------------------------------
# Set DASHBOARD_PASSWORD to require sign-in (leave blank to keep it open, e.g. if
# it already sits behind a trusted reverse proxy). Cookie is HMAC-signed.
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=
# Optional: explicit cookie-signing key (default: derived from the password).
# Generate with: openssl rand -hex 32
DASHBOARD_SECRET=
# Set to 1 when serving over HTTPS so the session cookie gets the Secure flag.
DASHBOARD_COOKIE_SECURE=

# DATABASE_URL is assembled automatically inside docker-compose from the vars
# above. Only set it here if you run the CLI/dashboard OUTSIDE docker:
# DATABASE_URL=postgresql://postgres:change-me@localhost:5433/rbhome

# --- Product sources (multi-source) ------------------------------------------
# CJdropshipping: mints an access token from email + API key (CJ dashboard → API).
CJ_API_EMAIL=
CJ_API_KEY=
# BigBuy (needs a paid subscription for PRODUCTION API access before it works).
BIGBUY_PRODUCTION_API_KEY=
BIGBUY_SANDBOX_API_KEY=

# --- OpenRouter (SEO copy = Claude Sonnet, images = Gemini 3 Pro) -------------
# LLM access is ALWAYS via OpenRouter — never a direct provider API key.
OPENROUTER_API_KEY=

# --- Shopify (custom app in the Partner dashboard; OAuth) --------------------
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
# Filled in by the Shopify OAuth flow; never paste tokens elsewhere:
SHOPIFY_ACCESS_TOKEN=

# --- Baserow (legacy; optional — only if you still run against Baserow) -------
# BASEROW_API_URL=https://api.baserow.io
# BASEROW_DATABASE_TOKEN=
# BASEROW_SUPPLIERS_TABLE_ID=
# BASEROW_PRODUCTS_TABLE_ID=
# BASEROW_SCAN_RUNS_TABLE_ID=
# BASEROW_PRODUCT_CHANGES_TABLE_ID=
# BASEROW_MANUAL_DECISIONS_TABLE_ID=
# BASEROW_SELECTION_BATCHES_TABLE_ID=
